    "todays_special": {
        "menu_item_1": {
            "name": "Paneer Butter Masala",
            "ingredients": [
                "Paneer",
                "Tomato",
                "Onion",
                "Butter",
                "Ghee",
                "Garlic",
                "Ginger",
                "Bell Pepper",
                "Whipped Cream",
                "Cheddar Cheese",
                "Spices (Turmeric, Red Chili Powder, Garam Masala)",
                "Water"
            ],
            "description": "A rich and creamy North Indian dish featuring paneer in a tomato-based gravy.",
            "recipe": "1. Dice 250g paneer into cubes. 2. Saut\u00e9 1 chopped onion in 2 tbsp butter and 1 tbsp ghee until golden. 3. Add 1 tbsp ginger-garlic paste and saut\u00e9 for a minute. 4. Add 2 chopped tomatoes and 1 chopped bell pepper, cook until softened. 5. Add spices: 1 tsp turmeric, 1 tsp red chili powder, and 1 tsp garam masala. 6. Add 100g tomato puree and cook for 5 minutes. 7. Add the paneer cubes and simmer for 5-7 minutes. 8. Stir in 50ml whipped cream and 25g grated cheddar cheese. 9. Garnish with a dollop of cream."
        },
        "menu_item_2": {
            "name": "Tandoori Chicken",
            "ingredients": [
                "Chicken",
                "Greek Yogurt",
                "Garlic",
                "Ginger",
                "Lemon Juice",
                "Spices (Tandoori Masala, Turmeric, Red Chili Powder, Garam Masala)",
                "Butter",
                "Onion",
                "Bell Pepper"
            ],
            "description": "Chicken marinated in yogurt and spices, then cooked in a tandoor oven.",
            "recipe": "1. Marinate 500g chicken pieces in a mixture of 200g Greek yogurt, 1 tbsp ginger-garlic paste, 1 tbsp lemon juice, 2 tbsp tandoori masala, 1 tsp turmeric, 1 tsp red chili powder, 1 tsp garam masala and salt. Marinate for at least 2 hours. 2. Preheat oven to 200\u00b0C. 3. Place chicken on a baking sheet. 4. Bake for 20-25 minutes, or until chicken is cooked through. 5. Grill onion and bell pepper along with chicken. 6. Brush with butter before serving."
        },
        "new_dish": {
            "name": "Salmon & Paneer Kofta Curry with Sweet Potato Mash & Spinach Salad",
            "ingredients": [
                "Salmon",
                "Paneer",
                "Sweet Potato",
                "Spinach",
                "Onion",
                "Garlic",
                "Ginger",
                "Tomato",
                "Egg (Chicken)",
                "Bread Crumbs",
                "Ghee",
                "Spices (Coriander Powder, Cumin Powder, Turmeric, Garam Masala, Red Chili Powder)",
                "Greek Yogurt",
                "Lemon Juice",
                "Olive oil",
                "Salt",
                "Pepper"
            ],
            "description": "An innovative dish blending Indian flavors with salmon and paneer kofta, served with a sweet potato mash and a fresh spinach salad.",
            "recipe": "1.  **Kofta:** Grind 200g salmon (skinless, boneless) with 100g paneer, 1/4 chopped onion, 1 tbsp breadcrumbs, 1 egg, 1/2 tsp ginger-garlic paste, salt, and pepper. Form into small balls. 2. Shallow fry koftas in ghee until golden. 3. **Curry:** Saut\u00e9 1 chopped onion in ghee. Add 1 tsp ginger-garlic paste, 1 chopped tomato, and cook until softened. Add 1 tsp coriander powder, 1/2 tsp cumin powder, 1/4 tsp turmeric, 1/2 tsp garam masala, and a pinch of red chili powder. Add water for consistency and simmer. Add the koftas into the gravy and cook for 5 mins. 4. **Sweet Potato Mash:** Boil 200g sweet potato until soft. Mash with a knob of butter, salt, and pepper. 5. **Spinach Salad:** Toss fresh spinach with a dressing of greek yogurt, lemon juice, salt, pepper and olive oil. 6. Serve kofta curry with sweet potato mash and spinach salad."
        }
    },
